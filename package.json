{
  "name": "travelsphere-workspace",
  "version": "1.0.0",
  "scripts": {
    "install:all": "npm install --prefix backend --legacy-peer-deps && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
